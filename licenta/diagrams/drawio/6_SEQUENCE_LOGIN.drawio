<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-22" agent="5.0" version="24.1.0" type="device">
  <diagram id="sequence_login" name="6. Sequence Login Flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Sequence Diagram - Login Flow" style="text;html=1;align=center;fontSize=14;fontStyle=1;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- Actors/Objects on top -->
        <mxCell id="user" value="User&#10;(Student/Profesor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor#1976D2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="60" width="120" height="60" as="geometry" />
        </mxCell>

        <mxCell id="angular" value="Angular&#10;Login Component" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor#1976D2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="60" width="120" height="60" as="geometry" />
        </mxCell>

        <mxCell id="api" value="PHP API&#10;AuthController" style="rounded=1;whiteSpace=wrap;html=1;fillColor#FFE6B3;strokeColor#FF9800;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="60" width="120" height="60" as="geometry" />
        </mxCell>

        <mxCell id="db" value="MySQL&#10;Database" style="rounded=1;whiteSpace=wrap;html=1;fillColor#E8F5E9;strokeColor#388E3C;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="60" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Lifelines (vertical dashed lines) -->
        <mxCell id="line_user" edge="1" parent="1" source="user" target="user" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;dashed=1;strokeColor=#666;endArrow=none;startArrow=none;" />
        <mxCell id="line_angular" edge="1" parent="1" source="angular" target="angular" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;dashed=1;strokeColor#666;endArrow=none;startArrow=none;" />
        <mxCell id="line_api" edge="1" parent="1" source="api" target="api" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;dashed=1;strokeColor#666;endArrow=none;startArrow=none;" />
        <mxCell id="line_db" edge="1" parent="1" source="db" target="db" style="edgeStyle=elbowEdgeStyle;elbow=vertical;html=1;dashed=1;strokeColor#666;endArrow=none;startArrow=none;" />

        <!-- 1. User enters credentials -->
        <mxCell id="msg1_rect" value="1. Introduce email &amp; parolă" style="text;html=1;fontSize=10;fontStyle=1;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="50" y="160" width="150" height="25" as="geometry" />
        </mxCell>

        <!-- 2. Click Login Button -->
        <mxCell id="msg2" value="2. Click &quot;Login&quot;" edge="1" parent="1" source="user" target="angular" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;endArrow=classic;" />
        <mxCell id="msg2_label" value="click event" style="text;html=1;fontSize=9;fillColor=#FFF;labelBackgroundColor=1;" vertex="1" connectedEdges="msg2" parent="1">
          <mxGeometry x="140" y="195" width="60" height="20" as="geometry" />
        </mxCell>

        <!-- 3. Validate on frontend -->
        <mxCell id="msg3_rect" value="3. Frontend validează email &amp; parolă&#10;(required fields, format)" style="text;html=1;fontSize=10;fillColor=#FFF9C4;" vertex="1" parent="1">
          <mxGeometry x="230" y="220" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- 4. POST request -->
        <mxCell id="msg4" value="4. POST /api/auth/login" edge="1" parent="1" source="angular" target="api" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;endArrow=classic;" />
        <mxCell id="msg4_label" value="email, password" style="text;html=1;fontSize=9;fillColor=#FFF;labelBackgroundColor=1;" vertex="1" connectedEdges="msg4" parent="1">
          <mxGeometry x="320" y="280" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- 5. Query DB -->
        <mxCell id="msg5" value="5. Query: SELECT * FROM teachers WHERE email=?" edge="1" parent="1" source="api" target="db" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;endArrow=classic;" />

        <!-- 6. Return user record -->
        <mxCell id="msg6" value="6. Return user record (if exists)" edge="1" parent="1" source="db" target="api" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=9;endArrow=classic;dashed=1;" />
        <mxCell id="msg6_label" value="user obj + hash" style="text;html=1;fontSize=9;fillColor=#FFF;labelBackgroundColor=1;" vertex="1" connectedEdges="msg6" parent="1">
          <mxGeometry x="510" y="360" width="70" height="20" as="geometry" />
        </mxCell>

        <!-- 7. Verify password -->
        <mxCell id="msg7_rect" value="7. Verify password hash&#10;(bcrypt_verify)" style="text;html=1;fontSize=10;fillColor=#FFF9C4;" vertex="1" parent="1">
          <mxGeometry x="410" y="390" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- 8. Generate JWT -->
        <mxCell id="msg8_rect" value="8. Generate JWT Token&#10;(valid 24h)" style="text;html=1;fontSize=10;fillColor#E8F5E9;" vertex="1" parent="1">
          <mxGeometry x="410" y="450" width="140" height="40" as="geometry" />
        </mxCell>

        <!-- 9. Return JWT -->
        <mxCell id="msg9" value="9. Return {token, user, role}" edge="1" parent="1" source="api" target="angular" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;endArrow=classic;dashed=1;" />
        <mxCell id="msg9_label" value="200 OK" style="text;html=1;fontSize=9;fillColor=#FFF;labelBackgroundColor=1;" vertex="1" connectedEdges="msg9" parent="1">
          <mxGeometry x="320" y="520" width="60" height="20" as="geometry" />
        </mxCell>

        <!-- 10. Save token -->
        <mxCell id="msg10_rect" value="10. Save token in localStorage&#10;&amp; set Auth header" style="text;html=1;fontSize=10;fillColor#E8F5E9;" vertex="1" parent="1">
          <mxGeometry x="230" y="555" width="150" height="40" as="geometry" />
        </mxCell>

        <!-- 11. Display success -->
        <mxCell id="msg11" value="11. Display success message" edge="1" parent="1" source="angular" target="user" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=10;endArrow=classic;dashed=1;" />

        <!-- 12. Redirect -->
        <mxCell id="msg12_rect" value="12. Redirect to Dashboard" style="text;html=1;fontSize=10;fillColor#E8F5E9;" vertex="1" parent="1">
          <mxGeometry x="50" y="620" width="150" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

